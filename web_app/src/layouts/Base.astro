---
/**
 * Base.astro — 앱 셸(topbar / 뷰 컨테이너 slot / 바텀시트 / 토스트 / 컨페티 캔버스).
 * 출처 마크업: (구) web_app/index.html <body> — 재발명 금지, 클래스/구조 그대로 이식.
 * 차이: data-i 빈 노드 → 언어별 SSR 텍스트(translate). 언어 스위처 = 동일 페이지의 타 언어 URL 링크.
 *
 * View Transitions: <ClientRouter /> (Astro 5). 정적 다중 페이지 간 SPA 유사 전환.
 * 상호작용(테마 토글 등 최소분만 여기서, 나머지는 2단계 island 로 위임 — 하단 STUB 주석 참조).
 */
import { ClientRouter } from 'astro:transitions';
import { translate } from '../lib/i18n';
import { altUrls } from '../lib/urls';
import type { DonationChannel, Lang } from '../config';
import { DONATION_CHANNELS, isDonationChannelPreparing, SUPPORTED_LANGS } from '../config';
import type { Instrument } from '../lib/storage';
import FunctionsFab from '../components/FunctionsFab.astro';
import '../styles/tokens.css';
import '../styles/app.css';
import '../styles/functions.css';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  /** 캐논(ko) 경로 — hreflang · 언어 스위처 링크 계산용. */
  canonicalPath: string;
  /** 뒤로가기 버튼 노출 + 대상 링크(홈이면 생략). */
  backHref?: string;
  /** 색인 제외(404 등 에러 페이지). 기본 false. */
  noindex?: boolean;
  /** 하단 고정 '후원하기' CTA 노출. 홈·커리큘럼 페이지는 false 로 숨긴다(부담 완화). 기본 true. */
  showDonate?: boolean;
  /**
   * 악기별 액센트 테마 축(05_tag-filter.md 단계 3) — `<html data-instrument>` SSR 값.
   * 콘텐츠(커리큘럼/레슨) 페이지 = 그 코스 `meta.instrument`(권위값, 고정).
   * 홈 = 기본 'guitar'(플래시 스크립트가 첫 페인트 전 localStorage 값으로 오버라이드할 수 있음).
   */
  instrument?: Instrument;
  /**
   * true = 랜딩(브라우징 필터) — 인라인 플래시 스크립트가 `riff_instrument` 로 위 instrument 를
   * 오버라이드해도 된다. false = 콘텐츠 페이지 — 스크립트가 절대 개입하지 않고 SSR 값을 고정한다.
   */
  instrumentFromFilter?: boolean;
  /**
   * Functions FAB(우하단 플로팅 진입) 노출 — 커리큘럼 세부·레슨 페이지에서만 true.
   * 랜딩은 카드 행(FunctionCards)으로 진입하고, 도구 전용 페이지는 이미 그 도구 화면이라 불필요
   * (20_metronome.md A2). 기본 false.
   */
  functions?: boolean;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  backHref,
  noindex = false,
  showDonate = true,
  instrument = 'guitar',
  instrumentFromFilter = false,
  functions = false,
} = Astro.props;
const alts = altUrls(canonicalPath);
const homeHref = lang === 'ko' ? '/' : `/${lang}/`;
const desc = description ?? translate(lang, 'home.lead');

const LANG_LABEL: Record<Lang, string> = { ko: '한글', en: 'EN', ja: '日本' };

/** 도네이션 채널 버튼 렌더 메타(아이콘만 — url/qr/준비중 여부는 config.ts DONATION_CHANNELS가 SSOT). */
const DONATION_BUTTONS: { channel: DonationChannel; iconClass: string; icon: string }[] = [
  { channel: 'toss', iconClass: 'pay-toss', icon: 'T' },
  { channel: 'kakaopay', iconClass: 'pay-kakao', icon: 'K' },
  { channel: 'paypal', iconClass: 'pay-paypal', icon: 'P' },
];
---

<!doctype html>
<html lang={lang} data-theme="light" data-instrument={instrument} data-instrument-filter={instrumentFromFilter ? 'true' : 'false'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* PWA (07_pwa 트랙 A) — 설치형 앱: 매니페스트·테마색·애플 홈설치 메타. */}
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FFFFFF" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#17171C" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon-180.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Riff" />

    <title>{title}</title>
    <meta name="description" content={desc} />
    {noindex ? <meta name="robots" content="noindex,follow" /> : null}

    {/* hreflang — 언어별 정적 대체 URL(SEO). x-default = ko */}
    {SUPPORTED_LANGS.map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(alts[l], Astro.site ?? Astro.url).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(alts.ko, Astro.site ?? Astro.url).href} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site ?? Astro.url).href} />

    {/* 테마 플래시 방지 + 테마 토글(문서 위임, View Transitions 후 재적용) */}
    <script is:inline>
      (function () {
        var apply = function () {
          try {
            var t = localStorage.getItem('riff_theme');
            document.documentElement.dataset.theme = t === 'dark' ? 'dark' : 'light';
          } catch (e) {}
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
        document.addEventListener('click', function (e) {
          var b = e.target && e.target.closest && e.target.closest('#themeBtn');
          if (!b) return;
          var next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          try {
            localStorage.setItem('riff_theme', next);
          } catch (e2) {}
          document.documentElement.dataset.theme = next;
        });
      })();
    </script>

    {/*
      악기 액센트 테마 플래시 방지(05_tag-filter.md 단계 3, riff_theme 패턴과 동일) —
      `data-instrument-filter="true"` 인 페이지(랜딩)에서만 localStorage `riff_instrument` 를 읽어
      `<html data-instrument>` 를 첫 페인트 전에 덮어쓴다. 콘텐츠(커리큘럼/레슨) 페이지는
      `data-instrument-filter="false"` 라 이 스크립트가 개입하지 않고 SSR 값(그 코스의 meta.instrument)이
      그대로 유지된다. astro:after-swap 에서도 재적용(swapRootAttributes 가 새 페이지의 <html> 속성을
      그대로 복사하므로, 매 네비게이션마다 이 판정을 다시 한다).
    */}
    <script is:inline>
      (function () {
        var apply = function () {
          try {
            if (document.documentElement.dataset.instrumentFilter !== 'true') return;
            var v = localStorage.getItem('riff_instrument');
            document.documentElement.dataset.instrument = v === 'bass' ? 'bass' : 'guitar';
          } catch (e) {}
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>

    {/* 서비스워커 등록(PWA 오프라인/설치) — 배포 도메인에서만(로컬 dev/preview 는 캐시 방지 위해 제외). */}
    <script is:inline>
      if (
        'serviceWorker' in navigator &&
        location.hostname !== 'localhost' &&
        location.hostname !== '127.0.0.1'
      ) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>

    <ClientRouter />

    {/*
      2단계 상호작용 부트스트랩(진도 하이드레이션·완료 액션·바텀시트·넛지 — technical_spec §8-A.5).
      astro:page-load 에서 (재)바인딩되므로 최초 로드·View Transitions 전환 모두 커버한다.
    */}
    <script src="../scripts/app.ts"></script>
  </head>
  <body>
    {/*
      커리큘럼 카드 썸네일 듀오톤 필터(전역, 페이지당 1회) — 카드마다 중복 정의 금지.
      1단계 feColorMatrix = 휘도 그레이스케일(Rec.709), 2단계 feComponentTransfer = shadow→highlight 2색 매핑.
      tableValues=[shadow, highlight] 를 0~1 정규화. 라이트: #0B2E6B→#7FB4FF, 다크: #050F24→#4E86D6.
      CSS 는 [data-theme] 속성 셀렉터로 light/dark 필터를 전환한다(런타임 JS 주입 없음 → View Transitions·Safari 안전).
    */}
    <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
      <filter id="duotone-light" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values=".2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.0431 0.4980"/>
          <feFuncG type="table" tableValues="0.1804 0.7059"/>
          <feFuncB type="table" tableValues="0.4196 1"/>
        </feComponentTransfer>
      </filter>
      <filter id="duotone-dark" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values=".2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.0196 0.3059"/>
          <feFuncG type="table" tableValues="0.0588 0.5255"/>
          <feFuncB type="table" tableValues="0.1412 0.8392"/>
        </feComponentTransfer>
      </filter>
      {/*
        베이스 악기용 초록 듀오톤(백로그 05 단계 3) — 파랑 스톱을 에메랄드 색상(hue≈143°)으로
        회전 후 채도 20%↓ 톤다운(쨍한 느낌 완화, 2026-07-10). 라이트: #156132→#8CF2B3, 다크: #082112→#5CC885.
        [data-instrument="bass"] 일 때만 CSS 가 이 필터로 전환(app.css). 기타는 파랑 필터 유지.
      */}
      <filter id="duotone-light-bass" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values=".2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.0824 0.5490"/>
          <feFuncG type="table" tableValues="0.3804 0.9490"/>
          <feFuncB type="table" tableValues="0.1961 0.7020"/>
        </feComponentTransfer>
      </filter>
      <filter id="duotone-dark-bass" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values=".2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  .2126 .7152 .0722 0 0  0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.0314 0.3608"/>
          <feFuncG type="table" tableValues="0.1294 0.7843"/>
          <feFuncB type="table" tableValues="0.0706 0.5216"/>
        </feComponentTransfer>
      </filter>
    </svg>

    <div class="app">
      <header class="topbar" id="topbar">
        {backHref ? (
          <a class="icon-btn" id="backBtn" href={backHref} aria-label="Back">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        ) : null}
        <a class="brand" id="brandHome" href={homeHref}>
          <svg class="pick" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2c4.4 0 8 2.6 8 6.4 0 3.1-2 5.2-3.9 7.2-1.4 1.5-2.1 3-2.5 4.9-.2 1-.9 1.5-1.6 1.5-.9 0-1.6-.8-1.9-2.1C9.3 21 9 17 8 14.6 6.9 12 4 11 4 8.4 4 4.6 7.6 2 12 2z"/>
          </svg>
          Riff
        </a>
        <div class="spacer"></div>

        {/* 언어 스위처 = 동일 페이지의 타 언어 정적 URL 링크(SEO·SSR). */}
        <div class="lang-seg" id="langSeg" role="tablist" aria-label="Language">
          {SUPPORTED_LANGS.map((l) => (
            <a href={alts[l]} class={l === lang ? 'active' : ''} hreflang={l}>{LANG_LABEL[l]}</a>
          ))}
        </div>

        <button class="icon-btn" id="themeBtn" aria-label="Toggle theme">
          <svg class="sun" width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="2"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.4 1.4M17.6 17.6L19 19M19 5l-1.4 1.4M6.4 17.6L5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <svg class="moon" width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M20 14.5A8 8 0 019.5 4 7 7 0 1020 14.5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        </button>

        {/* 닉네임 칩 — scripts/app.ts refreshNickChip() 이 localStorage 상태로 표시/토글 */}
        <button class="nick-chip" id="nickChip" style="display:none"><span id="nickText"></span></button>
      </header>

      <slot />

      {/* 하단 고정 도네이션 진입 — scripts/app.ts 가 클릭 시 도네이션 시트 open.
          홈·커리큘럼 페이지(showDonate=false)에서는 숨긴다(레슨 페이지에서만 노출). */}
      {showDonate && (
        <div class="footer-cta" id="footerCta">
          <button class="btn secondary" id="openDonateBtn"><span class="donate-heart" aria-hidden="true"></span> <span>{translate(lang, 'donate.footer')}</span></button>
        </div>
      )}
    </div>

    {/*
      바텀시트 3종 · 토스트 · 컨페티 — 마크업만 정적 이식(초기 hidden).
      open/close·Export/Import·도네이션 채널·닉네임 저장·컨페티 배선은 scripts/app.ts 가 담당한다.
    */}
    <div class="scrim" id="dreamScrim">
      <div class="sheet sheet-dream" role="dialog" aria-modal="true" aria-label={translate(lang, 'dream.tada')}>
        <div class="grip"></div>
        <div class="dream-stage">
          <span class="dream-tada" data-i="dream.tada">{translate(lang, 'dream.tada')}</span>
          <img id="dreamImg" class="dream-img" src="" alt="" />
        </div>
        <div id="dreamName" class="dream-name"></div>
        <p id="dreamLine" class="dream-line" data-i-html></p>
        <button class="btn" id="dreamDonateBtn" data-i="dream.cta">{translate(lang, 'dream.cta')}</button>
        <button class="btn ghost" data-close-sheet data-i="dream.later">{translate(lang, 'dream.later')}</button>
      </div>
    </div>

    <div class="scrim" id="donateScrim">
      <div class="sheet" role="dialog" aria-modal="true" aria-labelledby="donateH">
        <div class="grip"></div>

        {/* 채널 리스트 뷰 — 기본. 채널 클릭 시 scripts/app.ts 가 아래 상세 뷰로 전환한다. */}
        <div id="donateMain">
          <h2 id="donateH">{translate(lang, 'donate.title')}</h2>
          <p class="sh-sub">{translate(lang, 'donate.sub')}</p>
          <div class="save-amount"><div class="big" id="saveAmount"></div></div>
          <div class="pay-grid" id="payGrid">
            {DONATION_BUTTONS.map(({ channel, iconClass, icon }) => {
              const cfg = DONATION_CHANNELS[channel];
              const preparing = isDonationChannelPreparing(channel);
              return (
                <button
                  class={`pay-btn ${iconClass}`}
                  data-donate={channel}
                  data-qr={cfg.qr || undefined}
                  data-url={cfg.url || undefined}
                  disabled={preparing}
                  aria-disabled={preparing}
                >
                  <span class="ico">{icon}</span>
                  <span>{translate(lang, `donate.${channel}`)}</span>
                  {preparing ? <span class="pay-badge">{translate(lang, 'donate.preparing')}</span> : null}
                </button>
              );
            })}
          </div>
        </div>

        {/* 채널 상세 뷰 — 그리드 채널 클릭 시 진입(scripts/app.ts showDonateChannel). 기본 hidden.
            QR/링크 두 pane 을 세그먼트 토글로 오간다(기본 선택은 기기별 — app.ts 참조). */}
        <div class="qr-view" id="donateQrView" hidden>
          <button class="qr-back" id="qrBackBtn" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>{translate(lang, 'common.back')}</span>
          </button>

          <div class="lang-seg donate-tabs" id="donateTabs" role="tablist" aria-label={translate(lang, 'donate.title')}>
            <button type="button" data-donate-tab="qr" id="tabQrBtn" role="tab">{translate(lang, 'donate.tab_qr')}</button>
            <button type="button" data-donate-tab="link" id="tabLinkBtn" role="tab">{translate(lang, 'donate.tab_link')}</button>
          </div>

          <div class="qr-pane" id="qrPane">
            <img class="qr-img" id="qrImg" src="" alt="" />
            <p class="qr-hint">{translate(lang, 'donate.scan_qr')}</p>
          </div>

          <div class="link-pane" id="linkPane">
            <a class="btn" id="qrLinkBtn" href="#">{translate(lang, 'donate.open_link')}</a>
          </div>

          {/* 세무·실명 고지: 실제 송금 직전(결제 뷰)에 작게 노출 — 인트로는 깨끗하게 유지 */}
          <p class="donate-notice">{translate(lang, 'donate.notice')}</p>
        </div>

        <button class="btn ghost close-free" data-close-sheet>{translate(lang, 'donate.close')}</button>
      </div>
    </div>

    <div class="scrim" id="nickScrim">
      <div class="sheet" role="dialog" aria-modal="true" aria-labelledby="nickH">
        <div class="grip"></div>
        <h2 id="nickH">{translate(lang, 'nick.title')}</h2>
        <p class="sh-sub">{translate(lang, 'nick.sub')}</p>
        <input class="field" id="nickInput" maxlength="16" placeholder={translate(lang, 'nick.placeholder')} />
        <button class="btn" id="saveNickBtn">{translate(lang, 'nick.save')}</button>
        <button class="btn ghost" data-close-sheet>{translate(lang, 'nick.later')}</button>
      </div>
    </div>

    <div class="scrim" id="storageScrim">
      <div class="sheet" role="dialog" aria-modal="true" aria-labelledby="stH">
        <div class="grip"></div>
        <h2 id="stH">{translate(lang, 'storage.title')}</h2>
        <p class="sh-sub">{translate(lang, 'storage.sub')}</p>
        <div class="io-row">
          <button class="btn secondary" id="exportBtn">{translate(lang, 'storage.export')}</button>
          <button class="btn secondary" id="importBtn">{translate(lang, 'storage.import')}</button>
        </div>
        <textarea class="io-text" id="ioText" placeholder={translate(lang, 'storage.io_placeholder')}></textarea>
        <button class="btn ghost" data-close-sheet>{translate(lang, 'storage.close')}</button>
      </div>
    </div>

    {/* Functions 공통 셸 — FAB + 플로팅 오버레이(메트로놈 등). 커리큘럼/레슨 페이지에서만. */}
    {functions && <FunctionsFab lang={lang} />}

    <div class="toast-wrap" id="toastWrap"></div>
    <canvas id="confetti"></canvas>
  </body>
</html>
