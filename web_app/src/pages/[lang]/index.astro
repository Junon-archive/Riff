---
/**
 * /{lang}/ — 홈(en/ja, 접두 언어). ko 는 루트 index.astro 가 담당.
 */
import Base from '../../layouts/Base.astro';
import HomeView from '../../components/HomeView.astro';
import { translate } from '../../lib/i18n';
import { stripAndTruncate } from '../../views/textUtils';
import { PREFIXED_LANGS } from '../../lib/urls';
import type { Lang } from '../../config';

export function getStaticPaths() {
  return PREFIXED_LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const title = `${translate(lang, 'common.app_name')} — ${stripAndTruncate(translate(lang, 'home.title'), 60)}`;
---

<Base lang={lang} title={title} canonicalPath="/" showDonate={false}>
  <HomeView lang={lang} />
</Base>
