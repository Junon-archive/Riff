---
/**
 * /{lang}/c/{curriculum}/ — 커리큘럼 개요(en/ja).
 */
import Base from '../../../../layouts/Base.astro';
import CurriculumView from '../../../../components/CurriculumView.astro';
import { translate } from '../../../../lib/i18n';
import { findCurriculum, getManifest } from '../../../../lib/content';
import { cleanTitle } from '../../../../views/textUtils';
import { curriculumRoutes } from '../../../../lib/paths';
import { PREFIXED_LANGS, localize } from '../../../../lib/urls';
import type { Lang } from '../../../../config';
import { toInstrument } from '../../../../lib/storage';

export function getStaticPaths() {
  return PREFIXED_LANGS.flatMap((lang) =>
    curriculumRoutes().map((r) => ({ params: { lang, curriculum: r.curriculum } })),
  );
}

const lang = Astro.params.lang as Lang;
const { curriculum } = Astro.params;
const node = findCurriculum(getManifest(), curriculum!)!;
const canonicalPath = `/c/${curriculum}/`;
const title = `${cleanTitle(node.titles[lang])} — ${translate(lang, 'common.app_name')}`;
// 악기 액센트 테마(05_tag-filter.md 단계 3) — 콘텐츠 기반(B): 이 코스의 meta.instrument 가 권위값.
const instrument = toInstrument(node.instrument);
---

<Base
  lang={lang}
  title={title}
  canonicalPath={canonicalPath}
  backHref={localize(lang, '/')}
  showDonate={false}
  instrument={instrument}
  instrumentFromFilter={false}
  functions={true}
>
  <CurriculumView lang={lang} curriculumId={curriculum!} />
</Base>
