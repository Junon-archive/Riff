---
/**
 * / — 홈(ko, 기본 언어 · 접두 없음).
 */
import Base from '../layouts/Base.astro';
import HomeView from '../components/HomeView.astro';
import { translate } from '../lib/i18n';
import { stripAndTruncate } from '../views/textUtils';

const lang = 'ko';
const title = `${translate(lang, 'common.app_name')} — ${stripAndTruncate(translate(lang, 'home.title.guitar'), 60)}`;
---

<Base lang={lang} title={title} canonicalPath="/" showDonate={false} instrument="guitar" instrumentFromFilter={true}>
  <HomeView lang={lang} />
</Base>
