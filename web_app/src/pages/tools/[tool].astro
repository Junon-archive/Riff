---
/**
 * /tools/{tool}/ — Functions 도구 전용 페이지(ko, 기본 언어 · 접두 없음).
 * SSOT: 20_metronome.md PART A(A0 — 도구마다 독립 페이지, 허브 1개 아님).
 *
 * getStaticPaths 소스 = lib/functions.ts 의 `ready` 도구 → 21·22·23 은 레지스트리에 ready 를
 * 켜고 패널 컴포넌트만 꽂으면 이 라우트가 자동으로 생성된다.
 */
import Base from '../../layouts/Base.astro';
import MetronomePanel from '../../components/MetronomePanel.astro';
import { translate } from '../../lib/i18n';
import { readyFunctionTools } from '../../lib/functions';
import type { FunctionToolId } from '../../lib/functions';
import { toolPath } from '../../lib/urls';

export function getStaticPaths() {
  return readyFunctionTools().map((tool) => ({
    params: { tool: tool.id },
    props: { i18nPrefix: tool.i18nPrefix },
  }));
}

const lang = 'ko';
const tool = Astro.params.tool as FunctionToolId;
const { i18nPrefix } = Astro.props as { i18nPrefix: string };
const title = `${translate(lang, `fn.${tool}`)} — ${translate(lang, 'common.app_name')}`;
const description = translate(lang, `${i18nPrefix}.page_desc`);
---

<Base
  lang={lang}
  title={title}
  description={description}
  canonicalPath={toolPath(tool)}
  backHref="/"
  showDonate={false}
  instrumentFromFilter={true}
>
  <main class="view fn-view" id="view-tool" data-fn-tool={tool}>
    {tool === 'metronome' && <MetronomePanel lang={lang} standalone />}
  </main>
</Base>
