---
/**
 * HomeView.astro — 랜딩(홈). hero + 커리큘럼 카드 목록 + 티저 + 저장 안내 + 철학.
 * 출처: (구) index.html #view-home + _legacy/views/home.ts 카드 렌더. 카드는 <a> 링크(SSR·SEO).
 */
import { translate } from '../lib/i18n';
import { getManifest } from '../lib/content';
import { curriculumPath, localize } from '../lib/urls';
import { cleanTitle } from '../views/textUtils';
import ContactSection from './ContactSection.astro';
import FunctionCards from './FunctionCards.astro';
import type { Lang } from '../config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const manifest = getManifest();

/**
 * 악기 필터 칩 인프라: "입문/중급/고급" 등급 라벨 대신 악기 단위로만 필터한다.
 * 서로 다른 instrument 가 2종 이상일 때만 칩 행을 노출(지금은 기타 1종뿐이라 자동 숨김 —
 * 데이터가 늘어나면 하드코딩 분기 없이 자연히 나타난다). 판정은 SSR에서, 실제 필터링은
 * scripts/app.ts 가 data-instrument 로 카드를 in-place 토글한다.
 */
// 필터 칩 노출 순서: 기타 우선 → 베이스 → 그 외(등장순). manifest 커리큘럼 순서와 무관하게 고정한다.
const INSTRUMENT_ORDER = ['guitar', 'bass'];
const instruments = [...new Set(manifest.curricula.map((c) => c.instrument).filter((v): v is string => !!v))].sort(
  (a, b) => {
    const ia = INSTRUMENT_ORDER.indexOf(a);
    const ib = INSTRUMENT_ORDER.indexOf(b);
    return (ia === -1 ? INSTRUMENT_ORDER.length : ia) - (ib === -1 ? INSTRUMENT_ORDER.length : ib);
  },
);
const showInstrumentFilter = instruments.length >= 2;
---

<main class="view" id="view-home">
  <section class="hero">
    <span class="free-badge">🎁 <span>{translate(lang, 'free.badge')}</span></span>
    <h1
      class="display"
      data-title-guitar={translate(lang, 'home.title.guitar')}
      data-title-bass={translate(lang, 'home.title.bass')}
      set:html={translate(lang, 'home.title.guitar')}
    ></h1>
    <p class="lead">{translate(lang, 'home.lead')}</p>
  </section>

  {/*
    Functions 진입 카드 행(20_metronome.md A0) — 커리큘럼 카드 위, 아이콘+이름 4개.
    각 카드는 그 도구의 전용 페이지로 이동한다(랜딩엔 FAB 를 두지 않는다).
  */}
  <FunctionCards lang={lang} />

  {/*
    세그먼트 토글 — '전체' 없음, 항상 기타/베이스 중 하나만 노출(05_tag-filter.md 단계 2).
    기본 활성 = 기타(SSR). 실제 필터링/기억 복원은 scripts/app.ts 가 담당.
  */}
  <div class="filter-chips" id="instrumentFilter" hidden={!showInstrumentFilter}>
    {instruments.map((inst) => (
      <button type="button" class={`chip-btn${inst === 'guitar' ? ' active' : ''}`} data-filter-instrument={inst}>
        {translate(lang, `instrument.${inst}`)}
      </button>
    ))}
  </div>

  <div id="currList">
    {manifest.curricula.map((c) => (
      <a class="card curr-card tap" data-instrument={c.instrument ?? ''} data-curriculum={c.id} data-total-days={c.totalDays} href={localize(lang, curriculumPath(c.id))}>
        <div class={`curr-thumb${c.image ? '' : ' no-img'}`}>
          {c.image && (
            <img
              class="thumb-img"
              src={c.image}
              alt=""
              width="1200"
              height="800"
              loading="lazy"
              decoding="async"
            />
          )}
          <span class="chip">{translate(lang, 'curr.eyebrow')}</span>
        </div>
        <div class="curr-body">
          <h3>{cleanTitle(c.titles[lang])}</h3>
          {c.taglines && <p class="muted" style="margin:8px 0 0;font-size:14px">{c.taglines[lang]}</p>}
          {c.forWho && <p class="curr-for-who">{c.forWho[lang]}</p>}
          <div class="curr-meta">
            {c.durationMonths && (
              <span class="meta-pill">{translate(lang, 'curr.months_unit', { n: c.durationMonths })}</span>
            )}
            <span class="meta-pill">{c.totalDays} {translate(lang, 'curr.month.days')}</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="card teaser">
    <div class="emoji">🎬</div>
    <div>
      <h3>{translate(lang, 'home.teaser.title')}</h3>
      <p>{translate(lang, 'home.teaser.desc')}</p>
    </div>
  </div>

  {/* Export/Import 시트 open 은 scripts/app.ts(#openStorageBtn 클릭 위임)가 담당 */}
  <div class="storage-note">
    <span class="emoji">💾</span>
    <div>
      <p>{translate(lang, 'home.storage')}</p>
      <button id="openStorageBtn">{translate(lang, 'home.storage_cta')}</button>
    </div>
  </div>

  <div class="philosophy">
    <p set:html={translate(lang, 'home.philosophy')}></p>
  </div>

  <ContactSection lang={lang} />

  {/*
    악기 필터 FOUC 방지(05_tag-filter.md 단계 3) — 색(<html data-instrument>)은 Base.astro 의 head
    플래시 스크립트가 이미 처리하지만, 칩 active·카드 표시·hero 카피는 body 콘텐츠라 head 에서 잡을 수
    없다. 여기서 riff_instrument(localStorage)를 동기(is:inline)로 읽어 페인트 전에 즉시 복원한다.
    scripts/app.ts 의 renderInstrumentFilter() 와 동일 로직(소량 중복 — theme flash 패턴과 같은 이유로
    인라인 허용). astro:page-load 시 app.ts 가 다시 한 번 같은 값으로 렌더해 idempotent 하게 정합을
    맞춘다(중복 실행돼도 결과 동일).
  */}
  <script is:inline>
    (function () {
      try {
        var v = localStorage.getItem('riff_instrument') === 'bass' ? 'bass' : 'guitar';

        var filterRoot = document.getElementById('instrumentFilter');
        if (filterRoot) {
          var chips = filterRoot.querySelectorAll('.chip-btn');
          for (var i = 0; i < chips.length; i++) {
            chips[i].classList.toggle('active', chips[i].dataset.filterInstrument === v);
          }
        }

        var cards = document.querySelectorAll('#currList .curr-card');
        for (var j = 0; j < cards.length; j++) {
          cards[j].style.display = cards[j].dataset.instrument === v ? '' : 'none';
        }

        // 완료 커리큘럼 맨 아래로 (사용자별 진도 gh_state) — 페인트 전 재정렬(FOUC 없음).
        var list = document.getElementById('currList');
        if (list) {
          var st = {};
          try { st = JSON.parse(localStorage.getItem('gh_state') || '{}') || {}; } catch (e2) {}
          var prog = st.progress || {};
          var cc = list.querySelectorAll('.curr-card');
          for (var m = 0; m < cc.length; m++) {
            var cid = cc[m].dataset.curriculum;
            var tot = parseInt(cc[m].dataset.totalDays || '0', 10);
            var dn = (prog[cid] && prog[cid].completedDays && prog[cid].completedDays.length) || 0;
            if (cid && tot > 0 && dn >= tot) list.appendChild(cc[m]);
          }
        }

        var hero = document.querySelector('.hero h1[data-title-guitar]');
        if (hero) {
          var html = v === 'bass' ? hero.dataset.titleBass : hero.dataset.titleGuitar;
          if (html) hero.innerHTML = html;
        }
      } catch (e) {}
    })();
  </script>
</main>
